APP_NAME="NODO Catalog Manager"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-dominio.com
APP_TIMEZONE=America/Mexico_City

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Datos de la base de datos MySQL/MariaDB creada en tu hosting.
# El instalador web (/install) puede escribir estos valores por ti.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Sesiones y caché en archivos: no requieren tablas ni procesos adicionales,
# ideales para hosting compartido.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Cola de trabajos: se procesa mediante cron (ver INSTALL-HOSTINGER.md),
# no requiere un worker permanente.
QUEUE_CONNECTION=database

CACHE_STORE=file

# --- Correo (obligatorio para recuperación de contraseña y notificaciones) ---
# No uses la función mail() directa: configura un proveedor SMTP real.
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="info@nodo360mkt.site"
MAIL_FROM_NAME="${APP_NAME}"

# --- Usuario administrador inicial para instalación por consola (SSH) ---
# Solo se usan si ejecutas `php artisan db:seed` manualmente en vez del
# instalador web. Cambia estos valores antes de sembrar la base de datos.
# NODO_ADMIN_NAME="Administrador NODO 360"
# NODO_ADMIN_EMAIL=admin@nodo360mkt.site
# NODO_ADMIN_PASSWORD=CambiaEstaContrasenaSegura2026
